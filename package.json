{
  "name": "autorepuestos-rc",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "create-module": "node scripts/create-module.js",
    "dev": "concurrently -n \"SHELL,INVENTARIO,RRHH\" -c \"blue,green,yellow\" \"npm run shell\" \"npm run inventario\" \"npm run rrhh\"",
    "dev:shell": "npm run shell",
    "dev:inventario": "concurrently -n \"SHELL,INVENTARIO\" -c \"blue,green\" \"npm run shell\" \"npm run inventario\"",
    "dev:rrhh": "concurrently -n \"SHELL,RRHH\" -c \"blue,yellow\" \"npm run shell\" \"npm run rrhh\"",
    "shell": "npm start --prefix rc-shell -- --port 4200",
    "inventario": "npm start --prefix rc-inventario -- --port 4201",
    "rrhh": "npm start --prefix rc-rrhh -- --port 4202",
    "contabilidad": "npm start --prefix rc-contabilidad -- --port 4203",
    "dev:contabilidad": "concurrently -n \"SHELL,CONTABILIDAD\" -c \"blue,cyan\" \"npm run shell\" \"npm run contabilidad\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}